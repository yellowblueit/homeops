# Force LF line endings for shell scripts (critical for Linux containers)
*.sh text eol=lf
*.sql text eol=lf

# Docker files
Dockerfile text eol=lf
docker-compose.yml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Keep Windows line endings for Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
