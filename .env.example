# ===========================================
# Home Maintenance SaaS - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ---- Supabase Core ----
POSTGRES_PASSWORD=your-super-secret-postgres-password
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ---- Supabase Dashboard ----
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=your-dashboard-password

# ---- Supabase Auth - Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/v1/callback

# ---- Supabase Auth - Microsoft OAuth ----
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8000/auth/v1/callback

# ---- Supabase Auth - Email OTP ----
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_SMS_AUTOCONFIRM=false
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_OTP_EXP=600

# ---- Anthropic (Claude AI) ----
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ---- SMTP (Email Notifications) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-smtp-password
SMTP_FROM=Home Maintenance <noreply@yourdomain.com>

# ---- Application URLs ----
APP_URL=http://localhost:5173
PUBLIC_SUPABASE_URL=http://localhost:8000
PUBLIC_API_URL=http://localhost:3001

# ---- Frontend (Vite) ----
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:3001
